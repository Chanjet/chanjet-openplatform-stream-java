# ========================================================
# Cowen Store App Demo - Environment Configuration Template
# ========================================================
# Copy this file to .env and fill in your actual credentials.

# --- [Mode A] Production Environment (Default) ---
COWEN_APP_KEY=<PROD_APP_KEY>
COWEN_APP_SECRET=<PROD_APP_SECRET>
COWEN_OPENAPI_URL=https://openapi.chanjet.com
COWEN_MARKET_URL=https://market.chanjet.com
COWEN_STREAM_URL=https://stream-open.chanapp.chanjet.com

# --- [Mode B] Sandbox Environment (Uncomment to use) ---
# COWEN_APP_KEY=<SANDBOX_APP_KEY>
# COWEN_APP_SECRET=<SANDBOX_APP_SECRET>
# COWEN_OPENAPI_URL=https://openapi.inte.chanjet.com
# COWEN_MARKET_URL=https://market.inte.chanjet.com
# COWEN_STREAM_URL=https://stream-open-chanapp.inte.chanjet.com

# --- Shared Security Config ---
COWEN_ENCRYPT_KEY=<YOUR_16_BYTE_ENCRYPT_KEY>

# --- Demo App Networking ---
PORT=5000
REDIRECT_URI=http://localhost:5000/callback
COWEN_PROXY_URL=http://127.0.0.1:8080
