{
  "id": "cowen-wasm-auth-selfbuilt",
  "name": "Cowen Wasm Auth Selfbuilt",
  "version": "0.1.0",
  "transport": "wasm_extism",
  "requested_permissions": {
    "native.config:read": true,
    "native.auth:filter": true
  },
  "required_capabilities": {
    "native.config": "1.0.0",
    "native.auth": "1.0.0"
  },
  "contributes": {
    "wasm_interceptors": [
      {
        "name": "auth_interceptor",
        "app_modes": ["self-built", "oauth2"],
        "priority": 100
      }
    ]
  }
}
