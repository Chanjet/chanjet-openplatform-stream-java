{
  "id": "cowen-search-embedding",
  "name": "Cowen Search Embedding Plugin",
  "version": "0.5.0",
  "description": "Official semantic search embedding plugin via ONNX and Sidecar RPC",
  "command": "./cowen-search-embedding",
  "transport": "stdio",
  "requested_permissions": {
    "native.fs:cache_access": true,
    "native.network:fetch_asset": true,
    "native.compute:heavy": true
  },
  "contributes": {
    "providers": [
      {
        "type": "SearchEmbedding",
        "version": "1.0",
        "description": "基于 ONNX 的本地向量 Embedding 服务"
      }
    ]
  }
}
