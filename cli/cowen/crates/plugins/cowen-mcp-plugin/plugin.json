{
  "id": "cowen-mcp-plugin",
  "name": "Cowen MCP Server Plugin",
  "version": "1.0.0",
  "command": "./cowen-mcp-plugin",
  "default_config": {
    "log_level": "INFO"
  },
  "requested_permissions": {
    "native.api.registry:search": true,
    "native.api.registry:read": true,
    "native.api.registry:execute": true
  },
  "transport": "stdio",
  "required_capabilities": {
    "native.api.registry": "v1"
  },
  "contributes": {
    "cli_commands": [
      {
        "name": "",
        "description": "显示 MCP 插件命令行帮助信息"
      },
      {
        "name": "server",
        "description": "启动 MCP Server (标准 stdio 交互模式)"
      },
      {
        "name": "config",
        "description": "获取连接此 MCP 插件的 stdio 配置 JSON，用于配置 Cursor 等 IDE"
      }
    ]
  }
}
