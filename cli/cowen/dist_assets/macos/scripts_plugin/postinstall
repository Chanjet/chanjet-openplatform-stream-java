#!/bin/bash
# Cowen Plugin Post-installation script

BINARY_PATH="/usr/local/bin/cowen"
STAGING_DIR="/usr/local/share/cowen/staging"

# 1. 准确获取当前图形界面的真实登录用户（绕过 root 环境）
# macOS Installer app runs as root, but we want to install the plugin for the user who invoked it.
CURRENT_USER=$(stat -f "%Su" /dev/console)
if [ -z "$CURRENT_USER" ] || [ "$CURRENT_USER" = "root" ]; then
    # Fallback if not run via GUI or dev_console is weird
    if [ -n "$SUDO_USER" ]; then
        CURRENT_USER="$SUDO_USER"
    else
        CURRENT_USER=$(users | awk '{print $1}')
    fi
fi

REAL_HOME=$(eval echo ~$CURRENT_USER)
PLUGIN_DIR="$REAL_HOME/.cowen/plugins"

echo "📟 Installing plugins for user: $CURRENT_USER (Home: $REAL_HOME)"

# 2. 为该用户创建目录
mkdir -p "$PLUGIN_DIR"

# 3. 动态将 staging 目录下的所有插件移动到用户的真实目录下
if [ -d "$STAGING_DIR" ]; then
    for file in "$STAGING_DIR"/*; do
        if [ -e "$file" ]; then
            filename=$(basename "$file")
            echo "📦 Moving plugin $filename to $PLUGIN_DIR/"
            mv "$file" "$PLUGIN_DIR/"
            
            # 4. 把文件的所有权交还给真实用户
            chown -R "$CURRENT_USER" "$PLUGIN_DIR/$filename"
            
            # 5. 动态修改该用户的配置，启用插件 (利用 cowen 自身的功能)
            if [[ "$filename" != *.bundle ]]; then
                if [ -x "$BINARY_PATH" ]; then
                    # Wait for daemon to stabilize if it was just installed
                    sleep 1
                    echo "⚙️  Enabling plugin $filename within cowen CLI..."
                    sudo -u "$CURRENT_USER" "$BINARY_PATH" plugins enable "$filename" > /dev/null 2>&1 || true
                else
                    echo "⚠️  Cowen core binary not found at $BINARY_PATH, skip enabling plugin $filename."
                fi
            fi
        fi
    done
fi

# 6. 清理公共中转区
rm -rf "$STAGING_DIR"

exit 0
