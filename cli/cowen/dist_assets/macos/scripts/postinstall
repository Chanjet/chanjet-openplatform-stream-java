#!/bin/bash
# Cowen Post-installation script

# Path where the binary is installed by pkgbuild (base on --install-location /)
BINARY_PATH="/usr/local/bin/cowen"

if [ -f "$BINARY_PATH" ]; then
    echo "📟 Setting up Cowen daemon autostart service..."
    # Run as the current user (if possible) or at least trigger the install
    # For .pkg installed via Installer.app, this might run as root.
    # However, cowen daemon service install detects Home and target dirs.
    # If run as root, it might install to /var/root.
    # Usually, we want it for the logged-in user.
    
    # Get the logged in user
    CURRENT_USER=$(stat -f "%Su" /dev/console)
    
    if [ -n "$CURRENT_USER" ] && [ "$CURRENT_USER" != "root" ]; then
        sudo -u "$CURRENT_USER" "$BINARY_PATH" daemon service install > /dev/null 2>&1 || true
    else
        "$BINARY_PATH" daemon service install > /dev/null 2>&1 || true
    fi
fi

exit 0
