#!/bin/bash

echo "🗑️  Uninstalling Cowen CLI..."

if [ "$EUID" -ne 0 ]; then
  echo "❌ Please run this script with sudo: sudo cowen-uninstall"
  exit 1
fi

# Stop daemon if running
if [ -f "/usr/local/bin/cowen" ]; then
    CURRENT_USER=$(stat -f "%Su" /dev/console)
    if [ -n "$CURRENT_USER" ] && [ "$CURRENT_USER" != "root" ]; then
        sudo -u "$CURRENT_USER" /usr/local/bin/cowen daemon stop > /dev/null 2>&1 || true
    else
        /usr/local/bin/cowen daemon stop > /dev/null 2>&1 || true
    fi
fi

# Determine the actual user who ran sudo
TARGET_USER=$SUDO_USER
if [ -z "$TARGET_USER" ]; then
    TARGET_USER=$(stat -f "%Su" /dev/console)
fi

TARGET_HOME=$(eval echo ~$TARGET_USER)
COWEN_DIR="$TARGET_HOME/.cowen"

echo "🧹 Removing binaries..."
rm -f /usr/local/bin/cowen
rm -f /usr/local/bin/cowen-daemon

echo "🧹 Removing staging directories..."
rm -rf /usr/local/share/cowen/staging

echo "🧹 Removing user configuration and data ($COWEN_DIR)..."
rm -rf "$COWEN_DIR"

echo "🧹 Removing package receipts..."
pkgutil --forget com.chanjet.cowen.core > /dev/null 2>&1 || true
pkgutil --forget com.chanjet.cowen.aiplugin > /dev/null 2>&1 || true
pkgutil --forget com.chanjet.cowen.aarch64 > /dev/null 2>&1 || true
pkgutil --forget com.chanjet.cowen.x86_64 > /dev/null 2>&1 || true

echo "🧹 Removing uninstaller..."
rm -f /usr/local/bin/cowen-uninstall

echo "✅ Cowen CLI has been successfully uninstalled."
exit 0
