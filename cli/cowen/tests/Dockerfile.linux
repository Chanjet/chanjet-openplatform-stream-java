FROM rust:1.75-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-aiohttp \
    sqlite3 \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the entire workspace (or just the CLI if it's independent)
# Note: Adjust path if running from project root
COPY . .

# Ensure scripts are executable
RUN chmod +x tests/*.sh

# Run the test suite
CMD ["./tests/run_suites.sh"]
