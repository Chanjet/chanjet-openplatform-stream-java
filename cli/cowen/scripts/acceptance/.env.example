# =========================================================================
# Cowen CLI 验收测试环境变量配置文件模版 (.env.example)
# 请复制为 .env 并填写您在集测环境的真实凭证。注意：.env 文件禁止提交到 git
# =========================================================================

# 1. 商店应用 (集测)
STORE_APP_ORG_ID="<STORE_APP_ORG_ID>"
STORE_APP_SANDBOX_KEY="<STORE_APP_SANDBOX_KEY>"
STORE_APP_SANDBOX_SECRET="<STORE_APP_SANDBOX_SECRET>"
STORE_APP_PROD_KEY="<STORE_APP_PROD_KEY>"
STORE_APP_PROD_SECRET="<STORE_APP_PROD_SECRET>"

# 2. 自建应用
SELF_BUILT_APP_KEY="<SELF_BUILT_APP_KEY>"
SELF_BUILT_APP_SECRET="<SELF_BUILT_APP_SECRET>"

# 3. OAuth2 应用 & 消息加解密
OAUTH2_APP_KEY="<OAUTH2_APP_KEY>"
OAUTH2_MESSAGE_SECRET="<OAUTH2_MESSAGE_SECRET>"
OAUTH2_CERT="<OAUTH2_CERT>"
